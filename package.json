{
  "name": "distill-audio-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Distill Audio — warm, sourced narration & explainer audio generation (brief-to-spec → research → script → ElevenLabs TTS).",
  "scripts": {
    "type-check": "tsc --noEmit",
    "start": "bun run src/server.ts",
    "dev": "bun run --watch src/server.ts",
    "voices": "bun run scripts/list-voices.ts",
    "win:getoffzero": "bun run scripts/win-getoffzero.ts",
    "generate": "bun run src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@coinbase/cdp-sdk": "^1.51.1",
    "@x402/core": "^2.15.0",
    "@x402/evm": "^2.15.0",
    "@x402/express": "^2.15.0",
    "@x402/extensions": "^2.15.0",
    "@x402/fetch": "^2.15.0",
    "express": "^5.2.1",
    "viem": "^2.52.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "bun-types": "^1.3.0",
    "typescript": "^5.9.2"
  }
}
