# ── Distill Audio — environment ───────────────────────────────────────────
# Copy to .env and fill in. Only the two API keys are required to run.

# Required. ElevenLabs API key (https://elevenlabs.io → Profile → API Keys).
# Free tier = 10,000 credits/month at $0. Commercial license starts at the
# Starter tier ($6/mo). See cost.ts and the README licensing note.
ELEVENLABS_API_KEY=

# Required. Anthropic key for brief-to-spec (Haiku 4.5) + topic research
# (Sonnet 4.6). Reuse the same key as the other Distill agents (distill-agent/.env).
ANTHROPIC_API_KEY=

# ── x402 server (Part 2) ──────────────────────────────────────────────────
# Required for the paid HTTP server (src/server.ts). The Coinbase CDP
# facilitator that verifies + settles x402 payments. Reuse the same pair as
# distill-agent/.env.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Address that receives the 2.00 USDC per request (Base Mainnet). Same payTo
# as Refine (distill-agent).
PAYMENTS_RECEIVABLE_ADDRESS=0x104b5768FE505c400dd98F447665CB5c6fca388A

# Agent wallet private key (x402 settlement / on-chain identity). Same key as
# the other Distill agents. Keep it out of git (.env is gitignored).
AGENT_WALLET_PRIVATE_KEY=

# Port the server listens on. Railway injects this automatically.
PORT=3000

# Optional. Absolute path to ffmpeg when it is off-PATH (e.g. Homebrew on macOS:
# /opt/homebrew/bin/ffmpeg). On Railway ffmpeg is on PATH, so leave this unset.
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# Optional. Override the default narration voice (a real /v1/voices id).
# Defaults to George — warm, calm, mature audiobook narrator. See voices.ts.
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Optional. ElevenLabs model. Defaults to eleven_multilingual_v2 (10k char/req,
# best voice consistency for long-form narration, 1 credit/char).
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional. Free-tier credit allowance used by the cost gate (cost.ts). Lower
# this to whatever you have left this month so the gate warns accurately.
# FREE_TIER_CREDITS=10000
